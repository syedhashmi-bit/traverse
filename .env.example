WG_INTERFACE=wg0
WG_PORT=51820
WG_SUBNET=10.8.0.0/24
WG_SERVER_VPN_IP=10.8.0.1
WG_ENDPOINT=your-germany-vps-ip-or-domain
WG_DNS=1.1.1.1
DATABASE_PATH=database.db
SECRET_KEY=changeme-use-a-strong-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-use-a-strong-password

# TOTP 2FA (optional) — generate with: python -c "import pyotp; print(pyotp.random_base32())"
# TOTP_SECRET=

# Telegram alerts (optional) — set both to enable
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# Peer inactivity alert threshold in hours (0 = disabled)
# ALERT_INACTIVE_HOURS=24
